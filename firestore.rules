rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isNonEmptyString(field, maxLen) {
      return field is string && field.size() > 0 && field.size() <= maxLen;
    }

    function isOptionalString(field, maxLen) {
      return !(field in request.resource.data)
        || (request.resource.data[field] is string && request.resource.data[field].size() <= maxLen);
    }

    function hasValidEmail() {
      return request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$');
    }

    function hasValidPhone() {
      return request.resource.data.phone.matches('^[+0-9\\s()\\-]{7,20}$');
    }

    match /form/{docId} {
      allow create: if request.resource.data.keys().hasOnly([
          'type', 'fullName', 'email', 'phone', 'whatsapp', 'experience',
          'challenge', 'attempts', 'success', 'commitment', 'profile',
          'timezone', 'sourcePage', 'submittedAt'
        ])
        && isNonEmptyString(request.resource.data.type, 40)
        && isNonEmptyString(request.resource.data.fullName, 120)
        && isNonEmptyString(request.resource.data.email, 180)
        && hasValidEmail()
        && isNonEmptyString(request.resource.data.phone, 20)
        && hasValidPhone()
        && isOptionalString('whatsapp', 20)
        && isOptionalString('experience', 120)
        && isNonEmptyString(request.resource.data.challenge, 1200)
        && isOptionalString('attempts', 1200)
        && isOptionalString('success', 1200)
        && isOptionalString('commitment', 120)
        && isOptionalString('profile', 300)
        && isOptionalString('timezone', 80)
        && isOptionalString('sourcePage', 120)
        && request.resource.data.submittedAt == request.time;

      allow read: if true;
      allow update, delete: if false;
    }
  }
}
